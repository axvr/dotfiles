#!/usr/bin/env -S execlineb -W

# Given a PDF file and a destination path, passes the input through GhostScript
# to optimise it.  <https://askubuntu.com/a/256449>

importas -i input 1
importas -i output 2

gs -sDEVICE=pdfwrite -dCompatibilityLevel=1.4 -dPDFSETTINGS=/ebook -dNOPAUSE -dQUIET -dBATCH -sOutputFile=$output $input
